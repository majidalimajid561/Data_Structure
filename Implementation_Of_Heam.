import java.util.*;
class HeapMin {
	int [] arr;
	HeapMin(int capacity) {
		arr=new int[capacity+1];
		//	Arrays.fill(arr,Integer.MAX_VALUE);
	}
	int idx=1;

	void add(int val) {
		if(idx==arr.length) {
			System.out.println("Heap is full");
			return;
		}
		arr[idx++]=val;
		//rearrangemnet
		int root=idx-1;
		while(root!=1) {
			int parent=root/2;
			if(arr[parent]>arr[root]) {
				int temp =arr[parent];
				arr[parent]=arr[root];
				arr[root]=temp;
				root=parent;
			}
			else break;
		}
	}

	void info() {
		if(idx==1) {
			System.out.print("Heap is Empty");
			return;
		}
		for(int i=1; i<idx; i++) {
			System.out.print(arr[i]+" ");
		}
		System.out.println();
	}

	int peek() {
		if(size()==0) {
			System.out.println("Heap is Empty");
			return -1;
		}
		return arr[1];
	}
	int size() {
		return idx-1;
	}
	int remove() {
		if(size()==0) {
			System.out.println("Heap is Empty");
			return -1;
		}
		int min =arr[1];
		arr[1]=arr[idx-1];
		idx--;
		int root=1;
		//finding left and right Childs values and also preventind from Exception
		int leftValue=(2*root<=size())? arr[2*root]:Integer.MAX_VALUE;
		int rightValue=(2*root+1<=size())? arr[2*root+1]:Integer.MAX_VALUE;
		while(root<=size()) {
			if(arr[root]<leftValue&&arr[root]<rightValue) break;
			else {
				if(leftValue<rightValue) {
					int temp=arr [root];
					arr[root]=arr[2*root];
					arr[2*root]=temp;
					root=2*root;
				}
				else {
					//right child's value is small
					int temp=arr[root];
					arr[root]=arr[2*root+1];
					arr[2*root+1]=temp;
					root=2*root+1;
				}
			}
		}
		return min;
	}
}

class HeapMax {
	int[] arr;
	int idx=0;
	void add(int val) {
		if(idx==arr.length) {
			System.out.println("Heap is full");
			return;
		}
		arr[idx++]=val;
		// heapfiy UP
		int root=idx-1;
		while(root!=0) {
			int parent=(root-1)/2;
			if(arr[parent]<arr[root]) {
				int temp =arr[parent];
				arr[parent]=arr[root];
				arr[root]=temp;
				root=parent;
			}
			else break;
		}
	}

	void info() {
		if(idx==0) {
			System.out.print("Heap is Empty");
			return;
		}
		for(int i=0; i<idx; i++) {
			System.out.print(arr[i]+" ");
		}
		System.out.println();
	}
	int  size() {
		return idx;
	}
	int peek() {
		if(size()==0) {
			System.out.println("Heap is Empty!");
			return -1;
		}
		return arr[0];
	}

	int remove() {
		if(size()==0) {
			System.out.println("Heap is Empty!");
			return -1;
		}

		int max=arr[0];
		arr[0]=arr[idx-1];
		idx--;
		//heapfiy Down
		int root=0;
		while(root< size()) {
			// cheaking for existance of left child and right chlid
			int leftVal=(2*root+1<size())? arr[2*root+1]:Integer.MIN_VALUE;
			int rightVal=(2*root+2<size())? arr[2*root+2]:Integer.MIN_VALUE;
			if(arr[root]>leftVal&&arr[root]>rightVal) break;
			else {
				if(rightVal>rightVal) {
					//swap with righ child
					int temp=arr[root];
					arr[root]=arr[2*root+2];
					arr[2*root+2]=temp;
					root=2*root+2;
				}
				else {
					//swap with left  child
					int temp=arr[root];
					arr[root]=arr[2*root+1];
					arr[2*root+1]=temp;
					root=2*root+1;
				}
			}
		}
		return max;
	}
	HeapMax(int capacity) {
		arr=new int[capacity];
