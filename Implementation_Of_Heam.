	}
}
public class Main
{
	// creation of min heap by t.c(n)
	static void buildMinHeap2(int[] arr) {
		int n =arr.length;
		int parent=(n/2)-1;
		for (int i=parent; i>=0; i--) {
			heapifyDown2(arr,i);
		}
	}
	static void heapifyDown2(int[] arr, int parent) {
		int size=arr.length;
		while(parent<size) {
			int leftVal= (parent*2+1<size)? arr[parent*2+1]:Integer.MAX_VALUE;
			int rightVal= (parent*2+2<size)? arr[parent*2+2]:Integer.MAX_VALUE;
			if(arr[parent]<leftVal&&arr[parent]<rightVal) break;
			else {
				if(leftVal<rightVal) {
					int temp =arr[parent];
					arr[parent]=arr[parent*2+1];
					arr[parent*2+1]=temp;
					parent=parent*2+1;
				}
				else {
					int temp =arr[parent];
					arr[parent]=arr[parent*2+2];
					arr[parent*2+2]=temp;
					parent=parent*2+2;
				}
			}
		}
	}

	// Min Heap by Using heapifyUp with t.c(n log n)
	static void buildMinHeap1(int[] arr) {
		for (int i=0; i<arr.length; i++) {
			heapifyUp1(arr,i);
		}
	}
	static void	heapifyUp1(int[] arr,int root) {
		while(root!=0) {
			int parent=(root-1)/2;
			if(arr[root]<arr[parent]) {
				int temp=arr[root];
				arr[root]=arr[parent];
				arr[parent]=temp;
				root=parent;
			}
			else {
				break;
			}
		}
	}
	static void buildMaxHeap1(int[] arr, int parent, int size) {
		while(parent<size) {
			int leftVal=(parent*2+1<size)? arr[parent*2+1]:Integer.MIN_VALUE;
			int rightVal=(parent*2+2<size)? arr[parent*2+2]:Integer.MIN_VALUE;
			if(leftVal<arr[parent]&&rightVal<arr[parent]) break;
			else {
				if(leftVal>rightVal) {
					int temp =arr[parent];
					arr[parent]=arr[parent*2+1];
					arr[parent*2+1]=temp;
					parent=parent*2+1;
				}
				else {
					int temp =arr[parent];
					arr[parent]=arr[parent*2+2];
					arr[parent*2+2]=temp;
					parent=parent*2+2;
				}
			}
		}
  }
	static void HeapSort(int[] arr) {
		int size=arr.length;
		for(int i =(size/2-1); i>=0; i--) {
			buildMaxHeap1(arr,i,size);
		}
		for(int i=size-1; i>0; i--) {
			int temp = arr[0];
			arr[0]=arr[i];
			arr[i]=temp;
			buildMaxHeap1(arr,0,i);
		}
	}
	public static void main(String[] args) {
		int[] arr ={4,3,2,1};
		HeapSort(arr);
