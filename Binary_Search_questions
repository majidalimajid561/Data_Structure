	}

	static int peekValue(int[] arr) {
		int L=0;
		int R=arr.length-1;
		while(L<=R) {
			int mid =(L+R)/2;
			if(arr[mid]>arr[mid+1]&&arr[mid]>arr[mid-1])	return arr[mid];
			if(arr[mid]<arr[mid+1]) {
				R=mid-1;
			}
			else {
				L=mid+1;
			}
		}
		return -1;
	}

