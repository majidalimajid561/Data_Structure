	static int searchNum(int[] arr, int target) {
		int L=0;
		int R=arr.length-1;
		while(L<=R) {
			int mid =(L+R)/2;

			if(arr[mid]==target)  return mid;
			if(arr[mid]>target) {
				R=mid-1;
			}
			else {
				L=mid+1;
			}
		}
		return -1;
	}
	static int[] searchMatrics(int[][] mat,int k) {
		int Rows=mat.length;
		int Cols=mat[0].length;
		int  R = Rows*Cols-1;
		int  L = 0;
		while(L<=R) {
			int mid =(L+R)/2;
			int rowmid=mid/Cols;
			int colmid=mid%Cols;
			if(mat[rowmid][colmid]==k) return new int[] {rowmid, colmid};
			if(mat[rowmid][colmid]>k) {
				R=mid-1;
			}
			else {
				L=mid+1;
			}
		}
		return new int[] {-1};
	}

	static int firstOccurance(int[] arr, int target) {
		int L=0;
		int R=arr.length-1;
		int ans=0;
		while(L<=R) {
			int mid=(L+R)/2;
			if(arr[mid]==target) {
				ans=mid;
				R=mid-1;
			}
			else if(arr[mid]>target) {
				R=mid-1;
			}
			else {
				L=mid+1;
			}
		}
		return ans;
	}


